PORT=3001
JWT_SECRET=replace_with_a_long_random_secret
JWT_EXPIRES_IN=7d

VERCEL_FRONTEND_URL=https://your-app.vercel.app
CORS_ORIGIN=https://your-app.vercel.app

DATABASE_URL=mysql://user:password@aws.connect.psdb.cloud/database-name?sslaccept=strict

MYSQL_HOST=aws.connect.psdb.cloud
